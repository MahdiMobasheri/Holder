{
  "manifest_version": 3,
  "name": "Holder",
  "version": "2.0",
  "description": "Account Manager with Projects & Timers",
  "permissions": [
    "storage",
    "clipboardWrite",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}